{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeLens",
  "version": "1.0.0",
  "identifier": "ShanWenxiao.TimeLens-TimeManagementAppwithWidgets",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeLens",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "CN=67203FD7-3571-4CF3-9A8B-DE6BA454CE5B",
    "homepage": "https://github.com/PythonSmall-Q/TimeLens",
    "license": "MIT",
    "copyright": "Copyright (c) 2026 TimeLens Contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Screen time tracker and desktop widget manager",
    "longDescription": "TimeLens tracks how you spend time on your computer and provides handy desktop widgets for clocks, todos, and timers.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
